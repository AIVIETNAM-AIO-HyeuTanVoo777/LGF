# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you probably do not want to.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if the platform is Windows, and other is Linux,
#   Pipfile.lock might contain platform-specific dependencies.
#   So you might want to uncomment the following:
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains platform-specific dependencies
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains platform-specific dependencies
# pdm.lock
#   pdm.toml contains local configuration
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
